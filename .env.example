NODE_ENV=development
PORT=5000

# ── امنیت ──────────────────────────────────────────────────────
# حداقل ۳۲ کاراکتر: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_min_32_chars

# کلید admin-api — حداقل ۱۶ کاراکتر
INTERNAL_API_KEY=REPLACE_ME_internal_key

DEVICE_SECRET=REPLACE_ME_device_secret

# ── MySQL ────────────────────────────────────────────────────────
# در docker-compose: DB_HOST و DB_PORT توسط environment override می‌شوند
DB_HOST=mysql
DB_PORT=3306
DB_USER=appuser
DB_PASS=REPLACE_ME_db_password
DB_NAME=yarsalam

MYSQL_ROOT_PASSWORD=REPLACE_ME_root_password

# DB_SYNC=true فقط dev — در production همیشه false
DB_SYNC=false

DB_POOL_SIZE=45

# DB_SSL=true برای managed MySQL (RDS, PlanetScale)
# DB_SSL=true

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5001

# ── Python AI Services ────────────────────────────────────────
PYTHON_AI_URL=http://ml_service:8027
AI_ASSISTANT_URL=http://ai_assistant:8022
AI_MODERATION_URL=http://ai_moderation:8018
AI_SUPPORT_URL=http://ai_support:8016
AEO_TRACKER_URL=http://aeo_tracker:8030
PERSONALITY_AI_URL=http://personality:8023
FACE_VERIFICATION_URL=http://ai_verification:8017
CMS_API_URL=

# ── Third-party ───────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
GOOGLE_API_KEY=
SERPAPI_KEY=
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=
BACKLINK_API_KEY=
SEMRUSH_API_KEY=
